# Prisma datasource — required for migrations, generation, and seeding.
# Postgres connection string. Use a pooled URL for the app and a direct
# (non-pooled) URL for migrations if your provider distinguishes them
# (e.g. Neon, Supabase). Never commit the real value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/unkora?schema=public"

# Optional: a separate database Prisma uses to diff migrations safely.
# Recommended on Neon/Supabase so `prisma migrate dev` never touches prod data.
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/unkora_shadow?schema=public"
