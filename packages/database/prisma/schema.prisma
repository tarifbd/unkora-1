// ─────────────────────────────────────────────────────────────
// MODULE 13: RETURNS & EXCHANGES (dedicated schema)
// ─────────────────────────────────────────────────────────────

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  INSPECTED
  REFUNDED
  EXCHANGED
  CLOSED
}

enum ReturnType {
  RETURN
  EXCHANGE
}

enum ReturnReason {
  DAMAGED
  WRONG_ITEM
  NOT_AS_DESCRIBED
  DEFECTIVE
  CHANGED_MIND
  SIZE_ISSUE
  OTHER
}

model Return {
  id              String       @id @default(cuid())
  orderId         String
  userId          String
  type            ReturnType   @default(RETURN)
  status          ReturnStatus @default(REQUESTED)
  reason          ReturnReason
  reasonDetail    String?
  adminNote       String?
  refundAmount    Decimal?     @db.Decimal(10, 2)
  exchangeOrderId String?
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order Order    @relation(fields: [orderId], references: [id])
  user  User     @relation(fields: [userId], references: [id])
  items ReturnItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("returns")
}

model ReturnItem {
  id           String  @id @default(cuid())
  returnId     String
  productId    String
  productName  String
  sku          String?
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  condition    String  @default("UNKNOWN")
  exchangeProductId String?

  return  Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("return_items")
}

// ─────────────────────────────────────────────────────────────
// MODULE 19: CUSTOMER SEGMENTATION (dedicated schema)
// ─────────────────────────────────────────────────────────────

model CustomerSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  type        String   @default("CUSTOM")
  rules       Json     @default("{}")
  userCount   Int      @default(0)
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members CustomerSegmentMember[]

  @@map("customer_segments")
}

model CustomerSegmentMember {
  id         String   @id @default(cuid())
  segmentId  String
  userId     String
  addedAt    DateTime @default(now())

  segment CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([segmentId, userId])
  @@map("customer_segment_members")
}

// ─────────────────────────────────────────────────────────────
