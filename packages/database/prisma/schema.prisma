// Prisma schema for UNKORA — V2 Feature Expansion

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  DELIVERY_BOY
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum TokenType {
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  BKASH
  NAGAD
  ROCKET
  CARD
  BANK_TRANSFER
  COD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BookSubmissionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum ProductSource {
  INHOUSE
  SELLER
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum RefundReason {
  DEFECTIVE
  NOT_AS_DESCRIBED
  WRONG_ITEM
  DAMAGED_IN_TRANSIT
  OTHER
}

enum DeliveryBoyStatus {
  ACTIVE
  INACTIVE
  ON_DELIVERY
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  phone           String?    @unique
  passwordHash    String?
  firstName       String
  lastName        String
  avatarUrl       String?
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tokens          Token[]
  profile         CustomerProfile?
  address         Address[]
  cart            Cart?
  orders          Order[]
  wishlists       Wishlist[]
  reviews         Review[]
  bookSubmissions BookSubmission[]
  refunds         Refund[]
  blogPosts       BlogPost[]
  deliveryBoy     DeliveryBoy?
  auctionBids     AuctionBid[]
  wonAuctions     Auction[]       @relation("AuctionWinner")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Token {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
  @@map("tokens")
}

model CustomerProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  dateOfBirth DateTime?
  gender      String?
  preferences Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  label         String?
  recipientName String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  district      String
  division      String
  postalCode    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  imageUrl    String?
  color       String?
  icon        String?
  isFeatured  Boolean @default(false)
  isHot       Boolean @default(false)
  type        String  @default("physical")
  parentId    String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?       @db.Text
  shortDesc     String?
  categoryId    String
  brandId       String?
  sizeGuideId   String?
  warrantyId    String?
  source        ProductSource @default(INHOUSE)
  sku           String        @unique
  basePrice     Decimal       @db.Decimal(10, 2)
  salePrice     Decimal?      @db.Decimal(10, 2)
  stockQuantity Int           @default(0)
  lowStockAlert Int           @default(5)
  weight        Decimal?      @db.Decimal(8, 3)
  warrantyInfo  String?
  isActive      Boolean       @default(true)
  isFeatured    Boolean       @default(false)
  isDigital     Boolean       @default(false)
  digitalFileUrl String?
  isPreorder    Boolean       @default(false)
  preorderNote  String?
  preorderDate  DateTime?
  metaTitle     String?
  metaDesc      String?
  metaKeywords  String?
  tags          String[]
  deletedAt     DateTime?

  category        Category              @relation(fields: [categoryId], references: [id])
  brand           Brand?                @relation(fields: [brandId], references: [id])
  sizeGuide       SizeGuide?            @relation(fields: [sizeGuideId], references: [id])
  warranty        Warranty?             @relation(fields: [warrantyId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]
  colors          ProductColor[]
  labels          ProductLabelProduct[]
  notes           ProductNote[]
  bookDetail      BookDetail?
  orderItems      OrderItem[]
  cartItems       CartItem[]
  reviews         Review[]
  wishlists       Wishlist[]
  stockMovements  StockMovement[]
  submission      BookSubmission?
  flashDeal       FlashDeal?
  wholesalePrices WholesalePrice[]
  smartBars       SmartBar[]
  auctions        Auction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([isActive, isFeatured])
  @@index([source])
  @@index([sku])
  @@index([deletedAt])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  name          String
  sku           String  @unique
  price         Decimal @db.Decimal(10, 2)
  stockQuantity Int     @default(0)
  attributes    Json
  isActive      Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model BookDetail {
  id          String    @id @default(cuid())
  productId   String    @unique
  author      String
  publisher   String?
  isbn        String?   @unique
  language    String    @default("Bengali")
  pageCount   Int?
  edition     String?
  genres      String[]
  publishedAt DateTime?
  binding     String?
  translator  String?
  series      String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([author])
  @@index([isbn])
  @@map("book_details")
}

// ─────────────────────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String?    @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  addressId       String?
  deliveryBoyId   String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(COD)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingCost    Decimal       @db.Decimal(10, 2) @default(0)
  discount        Decimal       @db.Decimal(10, 2) @default(0)
  total           Decimal       @db.Decimal(10, 2)
  shippingAddress Json
  notes           String?
  cancelReason    String?
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User           @relation(fields: [userId], references: [id])
  address     Address?       @relation(fields: [addressId], references: [id])
  deliveryBoy DeliveryBoy?   @relation(fields: [deliveryBoyId], references: [id])
  items       OrderItem[]
  payment     Payment?
  timeline    OrderTimeline[]
  shipment    Shipment?
  refunds     Refund[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([deliveryBoyId])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)
  productName  String
  productSku   String
  productImage String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_timelines")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  gatewayRef      String?
  gatewayResponse Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([transactionId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  rating      Int
  title       String?
  body        String?
  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// ─────────────────────────────────────────────────────────────
// COUPONS & PROMOTIONS
// ─────────────────────────────────────────────────────────────

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  startsAt      DateTime     @default(now())
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([code])
  @@map("coupons")
}

model FlashDeal {
  id         String   @id @default(cuid())
  productId  String   @unique
  discount   Decimal  @db.Decimal(5, 2)
  startsAt   DateTime
  endsAt     DateTime
  isFeatured Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([isActive, endsAt])
  @@map("flash_deals")
}

model WholesalePrice {
  id        String  @id @default(cuid())
  productId String
  minQty    Int
  price     Decimal @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, minQty])
  @@map("wholesale_prices")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY & SHIPMENTS
// ─────────────────────────────────────────────────────────────

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  type      StockMovementType
  quantity  Int
  note      String?
  createdBy String?
  createdAt DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_movements")
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String         @unique
  courier        String
  trackingNumber String?
  trackingUrl    String?
  status         ShipmentStatus @default(PENDING)
  estimatedAt    DateTime?
  deliveredAt    DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

// ─────────────────────────────────────────────────────────────
// REFUNDS
// ─────────────────────────────────────────────────────────────

model Refund {
  id          String       @id @default(cuid())
  orderId     String
  userId      String
  amount      Decimal      @db.Decimal(10, 2)
  reason      RefundReason
  description String?
  status      RefundStatus @default(PENDING)
  adminNote   String?
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────
// DELIVERY BOYS
// ─────────────────────────────────────────────────────────────

model DeliveryBoy {
  id              String            @id @default(cuid())
  userId          String            @unique
  phone           String
  area            String?
  vehicleType     String?
  status          DeliveryBoyStatus @default(ACTIVE)
  totalDeliveries Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("delivery_boys")
}

// ─────────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────────

model BlogPost {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  content     String         @db.Text
  excerpt     String?
  coverImage  String?
  authorId    String
  status      BlogPostStatus @default(DRAFT)
  tags        String[]
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@map("blog_posts")
}

// ─────────────────────────────────────────────────────────────
// BOOK SUBMISSIONS
// ─────────────────────────────────────────────────────────────

model BookSubmission {
  id             String               @id @default(cuid())
  userId         String
  title          String
  authorName     String
  publisherName  String?
  isbn           String?
  language       String               @default("Bengali")
  pageCount      Int?
  edition        String?
  genres         String[]
  description    String               @db.Text
  coverImageUrl  String?
  suggestedPrice Decimal              @db.Decimal(10, 2)
  royaltyPercent Int                  @default(10)
  status         BookSubmissionStatus @default(PENDING)
  adminNote      String?
  reviewedBy     String?
  reviewedAt     DateTime?
  productId      String?              @unique
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("book_submissions")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────
// AUCTIONS (MODULE 2)
// ─────────────────────────────────────────────────────────────

enum AuctionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
  SOLD
}

model Auction {
  id             String        @id @default(cuid())
  productId      String
  title          String
  description    String?       @db.Text
  startingPrice  Decimal       @db.Decimal(10, 2)
  reservePrice   Decimal?      @db.Decimal(10, 2)
  currentPrice   Decimal       @db.Decimal(10, 2)
  bidIncrement   Decimal       @db.Decimal(10, 2) @default(10)
  status         AuctionStatus @default(DRAFT)
  startsAt       DateTime
  endsAt         DateTime
  winnerId       String?
  totalBids      Int           @default(0)
  featuredImage  String?
  isActive       Boolean       @default(true)
  createdBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  product Product      @relation(fields: [productId], references: [id])
  winner  User?        @relation("AuctionWinner", fields: [winnerId], references: [id])
  bids    AuctionBid[]

  @@index([status, startsAt, endsAt])
  @@index([productId])
  @@map("auctions")
}

model AuctionBid {
  id        String   @id @default(cuid())
  auctionId String
  userId    String
  amount    Decimal  @db.Decimal(10, 2)
  isWinning Boolean  @default(false)
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([auctionId, amount])
  @@index([userId])
  @@map("auction_bids")
}

// ─────────────────────────────────────────────────────────────
// BRANDS
// ─────────────────────────────────────────────────────────────

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  logoUrl     String?
  website     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
  @@map("brands")
}

// ─────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────

model Color {
  id        String   @id @default(cuid())
  name      String
  hexCode   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  productColors ProductColor[]

  @@unique([hexCode])
  @@map("colors")
}

model ProductColor {
  productId String
  colorId   String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color   @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@id([productId, colorId])
  @@map("product_colors")
}

// ─────────────────────────────────────────────────────────────
// ATTRIBUTES
// ─────────────────────────────────────────────────────────────

model Attribute {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  values AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String @id @default(cuid())
  attributeId String
  value       String

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("attribute_values")
}

// ─────────────────────────────────────────────────────────────
// SIZE GUIDES
// ─────────────────────────────────────────────────────────────

model SizeGuide {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("size_guides")
}

// ─────────────────────────────────────────────────────────────
// WARRANTIES
// ─────────────────────────────────────────────────────────────

model Warranty {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    String
  type        String   @default("seller")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("warranties")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT LABELS
// ─────────────────────────────────────────────────────────────

model ProductLabel {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#ef4444")
  bgColor   String   @default("#fef2f2")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products ProductLabelProduct[]

  @@map("product_labels")
}

model ProductLabelProduct {
  productId String
  labelId   String

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  label   ProductLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([productId, labelId])
  @@map("product_label_products")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT NOTES (ADMIN INTERNAL NOTES)
// ─────────────────────────────────────────────────────────────

model ProductNote {
  id        String   @id @default(cuid())
  productId String
  note      String   @db.Text
  createdBy String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_notes")
}

// ─────────────────────────────────────────────────────────────
// SMART BAR (PRODUCT PAGE ANNOUNCEMENT/OFFER BAR)
// ─────────────────────────────────────────────────────────────

model SmartBar {
  id        String   @id @default(cuid())
  productId String
  text      String
  linkUrl   String?
  bgColor   String   @default("#1d4ed8")
  textColor String   @default("#ffffff")
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("smart_bars")
}
