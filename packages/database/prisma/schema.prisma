  minRedeemPoints  Int      @default(100)
  maxRedeemPercent Int      @default(20)
  expiryDays       Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("loyalty_config")
}

model PointTransaction {
  id          String               @id @default(cuid())
  userId      String
