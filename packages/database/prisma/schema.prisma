// ─────────────────────────────────────────────────────────────
// MODULE 6: PREORDER V2
// ─────────────────────────────────────────────────────────────

enum PrepaymentType {
  NONE
  FIXED_AMOUNT
  PERCENTAGE
  FULL_PAYMENT
}

enum PreorderConfigStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  COMPLETED
  CANCELLED
}

enum PreorderOrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  WAITING_FOR_STOCK
  READY_TO_FULFILL
  CONVERTED_TO_ORDER
  CANCELLED
  REFUNDED
  COMPLETED
}

enum PreorderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PreorderEventType {
  CREATED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  CONFIRMED
  STOCK_AVAILABLE
  READY_TO_FULFILL
  CONVERTED_TO_ORDER
  CANCELLED
  REFUNDED
  CUSTOMER_NOTIFIED
  ADMIN_NOTE_ADDED
  STATUS_CHANGED
}

enum PreorderNotifChannel {
  EMAIL
  SMS
  IN_APP
}

enum PreorderNotifType {
  PREORDER_CONFIRMED
  PAYMENT_REMINDER
  STOCK_AVAILABLE
  DELIVERY_UPDATE
  CANCELLATION
  REFUND
  ORDER_CONVERTED
}

enum PreorderNotifStatus {
  PENDING
  SENT
  FAILED
}

model PreorderConfig {
  id                    String               @id @default(cuid())
  productId             String               @unique
  variantId             String?
  isEnabled             Boolean              @default(true)
  preorderTitle         String?
  preorderDescription   String?              @db.Text
  expectedReleaseDate   DateTime?
  expectedDeliveryStart DateTime?
  expectedDeliveryEnd   DateTime?
  preorderStartDate     DateTime?
  preorderEndDate       DateTime?
  stockLimit            Int?
  maxQtyPerCustomer     Int?
  prepaymentRequired    Boolean              @default(false)
  prepaymentType        PrepaymentType       @default(NONE)
  prepaymentAmount      Decimal?             @db.Decimal(10, 2)
  preorderPrice         Decimal?             @db.Decimal(10, 2)
  allowCancellation     Boolean              @default(true)
  cancellationDeadline  DateTime?
  autoConvertToOrder    Boolean              @default(false)
  status                PreorderConfigStatus @default(DRAFT)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  product        Product         @relation(fields: [productId], references: [id])
  preorderOrders PreorderOrder[]

  @@index([productId])
  @@index([status])
  @@map("preorder_configurations")
}

model PreorderOrder {
  id                   String                @id @default(cuid())
  preorderNumber       String                @unique
  customerId           String?
  productId            String
  variantId            String?
  configId             String
  orderId              String?
  quantity             Int
  unitPrice            Decimal               @db.Decimal(10, 2)
  totalAmount          Decimal               @db.Decimal(10, 2)
  prepaymentAmount     Decimal               @default(0) @db.Decimal(10, 2)
  remainingAmount      Decimal               @default(0) @db.Decimal(10, 2)
  paymentStatus        PreorderPaymentStatus @default(UNPAID)
  preorderStatus       PreorderOrderStatus   @default(PENDING_PAYMENT)
  customerName         String
  customerEmail        String?
  customerPhone        String
  shippingAddress      Json?
  note                 String?
  expectedDeliveryDate DateTime?
  convertedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  config        PreorderConfig         @relation(fields: [configId], references: [id])
  events        PreorderEvent[]
  notifications PreorderNotification[]

  @@index([customerId])
  @@index([preorderStatus])
  @@index([paymentStatus])
  @@index([configId])
  @@map("preorder_orders")
}

model PreorderEvent {
  id              String            @id @default(cuid())
  preorderOrderId String
  eventType       PreorderEventType
  message         String
  metadata        Json?
  createdBy       String?
  createdAt       DateTime          @default(now())

  preorderOrder PreorderOrder @relation(fields: [preorderOrderId], references: [id])

  @@index([preorderOrderId])
  @@map("preorder_events")
}

model PreorderNotification {
  id              String               @id @default(cuid())
  preorderOrderId String
  channel         PreorderNotifChannel
  notifType       PreorderNotifType
  status          PreorderNotifStatus  @default(PENDING)
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  preorderOrder PreorderOrder @relation(fields: [preorderOrderId], references: [id])

  @@index([preorderOrderId])
  @@map("preorder_notifications")
}

// ─────────────────────────────────────────────────────────────
// CONTACT FORM SUBMISSIONS
// ─────────────────────────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  repliedAt DateTime?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@map("contact_submissions")
}

// ─────────────────────────────────────────────────────────────
// PICKUP POINTS
// ─────────────────────────────────────────────────────────────

model PickupPoint {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  district    String
  mapUrl      String?
  phone       String?
  openHours   String?  @default("9am - 6pm")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pickup_points")
}

// ─────────────────────────────────────────────────────────────
// SHIPPING ZONES & RATES
// ─────────────────────────────────────────────────────────────

model ShippingZone {
  id          String   @id @default(cuid())
  name        String
  description String?
  countries   Json     @default("[]")
  divisions   Json     @default("[]")
  districts   Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rates ShippingRate[]

  @@map("shipping_zones")
}

model ShippingRate {
  id             String   @id @default(cuid())
  zoneId         String
  name           String
  carrier        String?
  minWeight      Decimal  @default(0) @db.Decimal(6,2)
  maxWeight      Decimal? @db.Decimal(6,2)
  baseRate       Decimal  @db.Decimal(10,2)
  perKgRate      Decimal  @default(0) @db.Decimal(10,2)
  freeAbove      Decimal? @db.Decimal(10,2)
  estimatedDays  String?  @default("3-5")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  zone ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@map("shipping_rates")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY V2 ENUMS
// ─────────────────────────────────────────────────────────────

enum InventoryMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  EXPIRED
  RESERVED
  RESERVATION_RELEASED
  RESERVATION_CONFIRMED
  INITIAL_STOCK
  CORRECTION
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum ReservationStatus {
  ACTIVE
  CONFIRMED
  RELEASED
  EXPIRED
}

enum AdjustmentReason {
  RECEIVED_GOODS
  DAMAGED
  EXPIRED
  THEFT
  CORRECTION
  RETURN_TO_SUPPLIER
  WRITE_OFF
  OTHER
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  OVERSTOCK
  EXPIRY_SOON
}

// ─────────────────────────────────────────────────────────────
// ADDON MANAGER
// ─────────────────────────────────────────────────────────────

model Addon {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  version     String   @default("1.0.0")
  icon        String?
  category    String   @default("general")
  isCore      Boolean  @default(false)
  isEnabled   Boolean  @default(false)
  config      Json     @default("{}")
  author      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("addons")
}

// ─────────────────────────────────────────────────────────────
// DYNAMIC POPUPS
// ─────────────────────────────────────────────────────────────

model Popup {
  id          String   @id @default(cuid())
  name        String
  title       String
  content     String   @db.Text
  imageUrl    String?
  buttonText  String?
  buttonUrl   String?
  type        String   @default("modal") // modal | banner | corner
  trigger     String   @default("on_load") // on_load | on_exit | on_scroll | after_delay
  delayMs     Int      @default(3000)
  showOnce    Boolean  @default(true)
  pages       Json     @default("[]") // empty = all pages
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("popups")
}

model BlockedEntity {
  id        String   @id @default(cuid())
  type      String   // 'ip' | 'phone' | 'device' | 'email'
  value     String
  reason    String?
  blockedBy String?
  createdAt DateTime @default(now())

  @@unique([type, value])
  @@map("blocked_entities")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY V2
// ─────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks         InventoryStock[]
  movements      InventoryMovement[]
  adjustments    StockAdjustment[]
  purchaseOrders PurchaseOrder[]

  @@map("warehouses")
}

model InventoryStock {
  id                String      @id @default(cuid())
  warehouseId       String
  productId         String
  variantId         String?
  quantityOnHand    Int         @default(0)
  quantityReserved  Int         @default(0)
  quantityDamaged   Int         @default(0)
  lowStockThreshold Int         @default(5)
  status            StockStatus @default(OUT_OF_STOCK)
  updatedAt         DateTime    @updatedAt

  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id])
  product      Product            @relation(fields: [productId], references: [id])
  reservations StockReservation[]

  @@unique([warehouseId, productId, variantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([status])
  @@map("inventory_stocks")
}

model InventoryMovement {
  id          String                @id @default(cuid())
  warehouseId String
  productId   String
  variantId   String?
  type        InventoryMovementType
  quantity    Int
  reference   String?
  note        String?
  createdBy   String?
  createdAt   DateTime              @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_movements")
}

model StockReservation {
  id        String            @id @default(cuid())
  stockId   String
  orderId   String
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  stock InventoryStock @relation(fields: [stockId], references: [id])

  @@unique([stockId, orderId])
  @@index([orderId])
  @@index([status])
  @@map("stock_reservations")
}

model StockAdjustment {
  id          String           @id @default(cuid())
  warehouseId String
  productId   String
  variantId   String?
  quantity    Int
  reason      AdjustmentReason
  status      AdjustmentStatus @default(APPROVED)
  note        String?
  approvedBy  String?
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@map("stock_adjustments")
}

model Supplier {
  id            String         @id @default(cuid())
  name          String
  code          String         @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  status        SupplierStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([status])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String
  warehouseId  String
  status       PurchaseOrderStatus @default(DRAFT)
  expectedDate DateTime?
  receivedAt   DateTime?
  notes        String?
  subtotal     Decimal             @default(0) @db.Decimal(10, 2)
  total        Decimal             @default(0) @db.Decimal(10, 2)
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  productId        String
  variantId        String?
  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitCost         Decimal @db.Decimal(10, 2)
  totalCost        Decimal @db.Decimal(10, 2)
  note             String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model InventoryAlert {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String?
  type        AlertType
  threshold   Int?
  currentQty  Int?
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([isResolved])
  @@map("inventory_alerts")
}

// ─── AI STUDIO MODULE ─────────────────────────────────────────────────────────

enum AiFeatureType {
  PRODUCT_CONTENT
  PRODUCT_SEO
  CATEGORY_SEO
  LANDING_PAGE
  BLOG_ARTICLE
  AD_COPY
  EMAIL_COPY
  FAQ
  IMAGE_ALT_TEXT
  META_DESCRIPTION
  SCHEMA_MARKUP
  AGENT_TASK
  CUSTOM_PROMPT
}

enum AiGenerationStatus {
  SUCCESS
  FAILED
}

enum AiContentStatus {
  DRAFT
  APPROVED
  APPLIED
  ARCHIVED
}

enum AiRelatedEntityType {
  PRODUCT
  CATEGORY
  BLOG
  LANDING_PAGE
  SEO
  EMAIL
  AD
  CUSTOM
}

enum AiAgentType {
  SEO_AGENT
  CONTENT_AGENT
  PRODUCT_AGENT
  LANDING_PAGE_AGENT
  CUSTOMER_SUPPORT_AGENT
  INVENTORY_AGENT
  MARKETING_AGENT
  CUSTOM_AGENT
}

enum AiAgentTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model AiSettings {
  id                String   @id @default(cuid())
  provider          String   @default("openai")
  defaultModel      String?
  isEnabled         Boolean  @default(true)
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(1000)
  systemPrompt      String?  @db.Text
  safetyMode        Boolean  @default(true)
  monthlyTokenLimit Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("ai_settings")
}

model AiGenerationLog {
  id            String             @id @default(cuid())
  userId        String?
  provider      String
  model         String?
  featureType   AiFeatureType
  inputSummary  String?            @db.Text
  outputSummary String?            @db.Text
  tokenInput    Int?
  tokenOutput   Int?
  estimatedCost Float?
  status        AiGenerationStatus
  errorMessage  String?            @db.Text
  createdAt     DateTime           @default(now())

  @@index([featureType])
  @@index([status])
  @@index([createdAt])
  @@map("ai_generation_logs")
}

model AiTemplate {
  id               String        @id @default(cuid())
  name             String
  featureType      AiFeatureType
  promptTemplate   String        @db.Text
  outputSchemaJson Json?
  isActive         Boolean       @default(true)
  createdBy        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("ai_templates")
}

model AiGeneratedContent {
  id                String               @id @default(cuid())
  featureType       AiFeatureType
  relatedEntityType AiRelatedEntityType?
  relatedEntityId   String?
  title             String
  contentJson       Json
  contentText       String               @db.Text
  status            AiContentStatus      @default(DRAFT)
  generatedBy       String?
  approvedBy        String?
  appliedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([featureType])
  @@index([status])
  @@index([relatedEntityId])
  @@map("ai_generated_contents")
}

model AiAgentIntegration {
  id            String      @id @default(cuid())
  name          String
  provider      String
  agentType     AiAgentType
  description   String?     @db.Text
  endpointUrl   String?
  apiKeyEnvName String?
  isEnabled     Boolean     @default(false)
  configJson    Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tasks AiAgentTask[]

  @@map("ai_agent_integrations")
}

model AiAgentTask {
  id                 String            @id @default(cuid())
  agentIntegrationId String?
  taskType           String
  status             AiAgentTaskStatus @default(PENDING)
  inputJson          Json
  outputJson         Json?
  errorMessage       String?           @db.Text
  startedAt          DateTime?
  completedAt        DateTime?
  createdBy          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  agent AiAgentIntegration? @relation(fields: [agentIntegrationId], references: [id])

  @@index([status])
  @@index([agentIntegrationId])
  @@map("ai_agent_tasks")
}

// ─── ADVANCED SEO MODULE ──────────────────────────────────────────────────────

enum SeoEntityType {
  PRODUCT
  CATEGORY
  BRAND
  PAGE
  BLOG
  LANDING_PAGE
  HOME
  CUSTOM
}

enum SeoAuditStatus {
  GOOD
  NEEDS_IMPROVEMENT
  POOR
}

enum SeoRedirectCode {
  R301
  R302
  R307
  R308
}

enum SeoChangeFrequency {
  always
  hourly
  daily
  weekly
  monthly
  yearly
  never
}

model SeoMetadata {
  id                    String        @id @default(cuid())
  entityType            SeoEntityType
  entityId              String?
  seoTitle              String?
  metaDescription       String?       @db.Text
  metaKeywords          String?
  slug                  String?
  canonicalUrl          String?
  robotsIndex           Boolean       @default(true)
  robotsFollow          Boolean       @default(true)
  ogTitle               String?
  ogDescription         String?       @db.Text
  ogImage               String?
  twitterTitle          String?
  twitterDescription    String?       @db.Text
  twitterImage          String?
  focusKeyword          String?
  secondaryKeywordsJson Json?
  schemaType            String?
  schemaJson            Json?
  hreflangJson          Json?
  seoScore              Int?
  lastAuditedAt         DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([slug])
  @@map("seo_metadata")
}

model SeoAudit {
  id              String         @id @default(cuid())
  entityType      SeoEntityType
  entityId        String?
  url             String?
  score           Int
  status          SeoAuditStatus
  issuesJson      Json
  suggestionsJson Json
  auditedBy       String?
  createdAt       DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("seo_audits")
}

model SeoRedirect {
  id         String          @id @default(cuid())
  sourcePath String          @unique
  targetPath String
  statusCode SeoRedirectCode @default(R301)
  isActive   Boolean         @default(true)
  hitCount   Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([sourcePath])
  @@index([isActive])
  @@map("seo_redirects")
}

model SeoInternalLink {
  id               String        @id @default(cuid())
  sourceEntityType SeoEntityType
  sourceEntityId   String
  targetEntityType SeoEntityType
  targetEntityId   String
  anchorText       String
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([sourceEntityId])
  @@map("seo_internal_links")
}

model SeoImageAlt {
  id         String        @id @default(cuid())
  entityType SeoEntityType
  entityId   String
  imageUrl   String
  altText    String
  titleText  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([entityId])
  @@map("seo_image_alts")
}

model SeoSitemapEntry {
  id               String             @id @default(cuid())
  url              String             @unique
  entityType       SeoEntityType?
  entityId         String?
  priority         Float              @default(0.5)
  changeFrequency  SeoChangeFrequency @default(weekly)
  includeInSitemap Boolean            @default(true)
  lastModified     DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([includeInSitemap])
  @@map("seo_sitemap_entries")
}

model SeoSettings {
  id                     String   @id @default(cuid())
  siteName               String   @default("UNKORA")
  defaultTitle           String?
  titleTemplate          String   @default("%s | UNKORA")
  defaultMetaDescription String?  @db.Text
  defaultOgImage         String?
  robotsTxt              String?  @db.Text
  enableAutoSitemap      Boolean  @default(true)
  enableSchemaMarkup     Boolean  @default(true)
  enableOpenGraph        Boolean  @default(true)
  enableTwitterCards     Boolean  @default(true)
  enableCanonicalUrls    Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("seo_settings")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT Q&A
// ─────────────────────────────────────────────────────────────

enum QuestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProductQuestion {
  id        String         @id @default(cuid())
  productId String
  userId    String?
  guestName String?
  body      String         @db.Text
  status    QuestionStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  user     User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers  ProductAnswer[]

  @@index([productId])
  @@index([status])
  @@map("product_questions")
}

model ProductAnswer {
  id         String   @id @default(cuid())
  questionId String
  userId     String?
  isAdmin    Boolean  @default(false)
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@map("product_answers")
}

// ─────────────────────────────────────────────────────────────
// BUNDLE OFFERS
// ─────────────────────────────────────────────────────────────

model BundleOffer {
  id            String       @id @default(cuid())
  title         String
  description   String?
  isActive      Boolean      @default(true)
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal      @db.Decimal(10, 2)
  minItems      Int          @default(2)
  maxUses       Int?
  usedCount     Int          @default(0)
  startDate     DateTime?
  endDate       DateTime?
  imageUrl      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items BundleOfferItem[]

  @@index([isActive])
  @@map("bundle_offers")
}

model BundleOfferItem {
  id            String @id @default(cuid())
  bundleOfferId String
  productId     String
  quantity      Int    @default(1)

  bundle  BundleOffer @relation(fields: [bundleOfferId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleOfferId, productId])
  @@index([bundleOfferId])
  @@map("bundle_offer_items")
}

// ─────────────────────────────────────────────────────────────
// RAG CUSTOMER SUPPORT KNOWLEDGE BASE
// ─────────────────────────────────────────────────────────────

enum RagDocumentStatus {
  PENDING
  INDEXED
  FAILED
}

enum RagDocumentCategory {
  FAQ
  POLICY
  PRODUCT
  SHIPPING
  RETURNS
  GENERAL
}

model RagDocument {
  id          String              @id @default(cuid())
  title       String
  content     String              @db.Text
  category    RagDocumentCategory @default(GENERAL)
  source      String?
  status      RagDocumentStatus   @default(PENDING)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  chunks RagDocumentChunk[]

  @@index([category])
  @@index([status])
  @@map("rag_documents")
}

model RagDocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String   @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())

  document RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("rag_document_chunks")
}

// ─────────────────────────────────────────────────────────────
// VIRTUAL TRIAL ROOM
// ─────────────────────────────────────────────────────────────

enum TryOnStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model VirtualTryOnSession {
  id             String      @id @default(cuid())
  userId         String?
  productId      String
  variantId      String?
  userImageUrl   String?
  resultImageUrl String?
  status         TryOnStatus @default(PENDING)
  errorMessage   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user    User?   @relation("UserTryOnSessions", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@map("virtual_try_on_sessions")
}
