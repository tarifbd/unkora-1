# App
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-domain.com

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (Upstash)
REDIS_URL=redis://default:password@your-upstash-host:6379

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Unkora <noreply@unkora.com>

# AWS S3 (or Cloudinary for images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET=unkora-uploads
AWS_ENDPOINT=  # leave empty for real AWS

# Payment Gateways
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_SANDBOX=true
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_SANDBOX=true

# AI (optional)
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_MODEL=gpt-3.5-turbo

# SMS
SMS_PROVIDER=ssl_wireless
SSL_WIRELESS_API_KEY=
SSL_WIRELESS_SID=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# App URLs
API_BASE_URL=https://api.your-domain.com
SUCCESS_URL=https://your-domain.com/checkout/success
FAIL_URL=https://your-domain.com/checkout/fail
CANCEL_URL=https://your-domain.com/checkout/cancel
IPN_URL=https://api.your-domain.com/api/v1/payments/sslcommerz/ipn
