# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://unkora:unkora_pass@localhost:5432/unkora_db"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-secure-random-string-min-64-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-a-different-secure-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ── API ───────────────────────────────────────────────────
API_PORT=4000
API_PREFIX="api"
NODE_ENV="development"
CORS_ORIGINS="http://localhost:3000"

# ── Web ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Typesense ─────────────────────────────────────────────
TYPESENSE_HOST="localhost"
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL="http"
TYPESENSE_API_KEY="change-me-typesense-api-key"

# ── Cloudflare R2 (file storage) ──────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="unkora-assets"
R2_PUBLIC_URL=""

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@unkora.com"
